datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  password         String
  role             String            @default("candidate")
  avatar           String?
  name             String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  candidateProfile CandidateProfile?
  recruiterProfile RecruiterProfile?

  @@map("users")
}

model CandidateProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email        String
  phoneNumber  String
  skills       String[]
  experience   String
  education    String
  resume       String
  githubLink   String?
  linkedInLink String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  applications Application[]

  @@map("candidate_profiles")
}

model RecruiterProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String   @map("company_name")
  website     String
  description String
  location    String
  logo        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jobs        Job[]

  @@map("recruiter_profiles")
}

model Job {
  id                  String   @id @default(uuid())
  title               String
  description         String
  salaryRange         String   @map("salary_range")
  location            String
  employmentType      String   @map("employment_type")
  experienceLevel     String   @map("experience_level")
  requiredSkills      String[] @map("required_skills")
  vacancyCount        Int      @map("vacancy_count")
  applicationDeadline DateTime @map("application_deadline")
  remoteInfo          String   @map("remote_info")

  recruiterId String           @map("recruiter_id")
  recruiter   RecruiterProfile @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  applications Application[]

  @@map("jobs")
}

model Application {
  id             String            @id @default(uuid())
  applicationId  String            @unique @map("application_id")
  jobId          String            @map("job_id")
  job            Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId    String?           @map("candidate_id")
  candidate      CandidateProfile? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  fullName       String            @map("full_name")
  email          String
  phone          String
  coverLetter    String?           @map("cover_letter")
  linkedInUrl    String?           @map("linkedin_url")
  status         String            @default("pending")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  // Relations
  resume         Resume?

  @@map("applications")
}

model Resume {
  id            String      @id @default(uuid())
  fileName      String      @map("file_name")
  fileSize      Int         @map("file_size")
  mimeType      String      @map("mime_type")
  url           String
  applicationId String      @unique @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("resumes")
}
